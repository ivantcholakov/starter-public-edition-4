{
    "config": {
        "preferred-install": "dist",
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/installers": true,
            "oomphinc/composer-installers-extender": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "installer-types": ["library", "component"],
        "installer-paths": {
            "../public/assets/composer-asset/{$vendor}/{$name}/": [
                "type:component"
            ]
        }
    },
    "require": {
        "php": ">=8.2.0",
        "paragonie/sodium_compat": "2.5.0",
        "oomphinc/composer-installers-extender": "^2.0",
        "codeigniter/framework": "3.1.13",
        "symfony/polyfill-php83": "1.38.1",
        "symfony/polyfill-php84": "1.38.1",
        "symfony/polyfill-php85": "1.38.1",
        "symfony/polyfill-ctype": "1.37.0",
        "symfony/polyfill-mbstring": "1.38.1",
        "symfony/polyfill-iconv": "1.37.0",
        "symfony/polyfill-intl-grapheme": "1.38.1",
        "symfony/polyfill-intl-idn": "1.38.1",
        "symfony/polyfill-intl-icu": "1.38.0",
        "symfony/polyfill-intl-messageformatter": "1.38.0",
        "symfony/polyfill-intl-normalizer": "1.38.0",
        "symfony/polyfill-uuid": "1.37.0",
        "symfony/deprecation-contracts": "3.7.0",
        "symfony/string": "7.4.13",
        "symfony/options-resolver": "7.4.8",
        "symfony/process": "7.4.13",
        "symfony/filesystem": "7.4.11",
        "symfony/finder": "7.4.8",
        "psr/cache": "3.0.0",
        "fg/multiplayer": "1.2.1",
        "voku/portable-utf8": "6.1.1",
        "erusev/parsedown": "1.8.0",
        "erusev/parsedown-extra": "0.8.1",
        "pixel418/markdownify": "2.3.3",
        "mustache/mustache": "3.2.0",
        "netcarver/textile": "4.1.4",
        "twig/twig": "3.27.1",
        "twig/string-extra": "3.24.0",
        "salesforce/handlebars-php": "3.0.1",
        "scssphp/scssphp": "2.1.0",
        "matthiasmullie/minify": "1.3.75",
        "t1st3/php-json-minify": "0.6.2",
        "whichbrowser/parser": "2.1.8",
        "ezyang/htmlpurifier": "4.19.0",
        "ivantcholakov/codeigniter-phpmailer": "1.5.0",
        "stevenmaguire/oauth2-microsoft": "2.2.0",
        "guzzlehttp/guzzle": "7.11.1",
        "intervention/image": "2.7.2",
        "yohang88/letter-avatar": "1.0.5",
        "athlon1600/php-proxy": "5.2.0",
        "components/jquery": "3.6.0",
        "components/modernizr": "3.5.0",
        "components/webfontloader": "1.6.3",
        "components/highlightjs": "9.16.2",
        "scrivo/highlight.php": "9.18.1.9",
        "desandro/imagesloaded": "4.1.4",
        "desandro/masonry": "4.2.2"
    }
}
